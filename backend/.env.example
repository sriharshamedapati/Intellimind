# INTELLMIND Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Supabase (Data DB) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ── Supabase (Auth DB) ──
AUTH_SUPABASE_URL=https://your-auth-project.supabase.co
# WARNING: Do NOT use a `sb_publishable_...` key here.
# For backend JWT verification via auth.get_user(), use the `service_role` key (or `anon` key if `service_role` is unavailable).
AUTH_SUPABASE_KEY=your-auth-supabase-service-role-key

# ── Google Gemini AI ──
GEMINI_API_KEY=your-gemini-api-key

# ── CORS (optional — comma-separated origins) ──
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5501

# ── External APIs (Optional) ──
# MAYA_CA_BUNDLE=/path/to/cert.pem
# HOOT_CA_BUNDLE=/path/to/cert.pem
